<Window x:Class="zadanie2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zadanie"
        Height="600"
        Width="900">

    <!-- Główna siatka -->
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Górna belka -->
        <Grid Grid.Row="0" Background="Gainsboro">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Przycisk1"/>

            <Button Grid.Column="1"
                    Content="Przycisk2"/>

            <!-- alternatywny styl -->
            <Button Grid.Column="3"
                    Content="ALT"
                    Style="{StaticResource AltButtonStyle}"/>

        </Grid>

        <!-- Środkowa część -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEWA BELKA (sub-siatka) -->
            <Grid Grid.Column="0"
                  Background="LightGray">

                <!-- Styl tylko dla tej sub-siatki -->
                <Grid.Resources>

                    <Style TargetType="Button">
                        <Setter Property="Background"
                                Value="Khaki"/>
                    </Style>

                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Content="Przycisk3"/>

                <Button Grid.Row="1"
                        Content="Przycisk4"/>

                <!-- alternatywny -->
                <Button Grid.Row="2"
                        Content="ALT"
                        Style="{StaticResource AltButtonStyle}"/>

            </Grid>

            <!-- PRZESTRZEŃ ZAWARTOŚCI -->
            <Border Grid.Column="1"
                    Margin="10"
                    BorderThickness="2"
                    BorderBrush="Black">

                <TextBlock Text="?"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Border>

        </Grid>

        <!-- DOLNA BELKA -->
        <Grid Grid.Row="2"
              Background="Gainsboro">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Przycisk5"/>

            <!-- alternatywny -->
            <Button Grid.Column="2"
                    Content="ALT"
                    Style="{StaticResource AltButtonStyle}"/>

        </Grid>

    </Grid>

</Window>